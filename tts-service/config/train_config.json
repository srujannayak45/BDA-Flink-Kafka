{
    "model": "xtts_v2",
    "dataset_path": "../data/dataset",
    "output_path": "../data/checkpoints",
    "reference_audio": "../data/reference/reference_commentary_clean.wav",
    "training": {
        "epochs": 50,
        "batch_size": 2,
        "learning_rate": 5e-6,
        "grad_accumulation_steps": 4,
        "checkpoint_interval": 10,
        "early_stopping_patience": 5,
        "warmup_steps": 100,
        "weight_decay": 0.01,
        "max_audio_length_secs": 15,
        "eval_split_ratio": 0.1
    },
    "inference": {
        "temperature": 0.65,
        "length_penalty": 1.0,
        "repetition_penalty": 2.0,
        "top_k": 50,
        "top_p": 0.85,
        "speed": 1.1
    },
    "voice_characteristics": {
        "description": "Energetic cricket sports commentary",
        "target_rate": 1.1,
        "target_pitch": "medium-high",
        "style": "excited, fast-paced, professional"
    }
}
